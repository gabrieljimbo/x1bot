# X1Bot Security Environment Variables Template
# Copy this to .env and fill in the real values

NODE_ENV=production
PORT=3041

# Domains
API_DOMAIN=api.x1bot.com
FRONTEND_URL=https://app.x1bot.com
CORS_ORIGIN=https://app.x1bot.com

# Database (Isolated in Docker Network)
# Use 'postgres_vps' as host if running via docker-compose
DATABASE_URL=postgresql://db_user:db_password@postgres_vps:5432/db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_NAME=db_name

# Redis
REDIS_HOST=redis_vps
REDIS_PORT=6379
REDIS_PASSWORD=change_this_to_a_random_long_string

# Secrets (Rotate regularly!)
JWT_SECRET=use_a_strong_random_secret_at_least_32_chars
WEBHOOK_SECRET=use_a_strong_random_secret_for_hmac

# Minio / S3
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=change_this_too

# Security Calibration
TRUST_PROXY=1
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100
