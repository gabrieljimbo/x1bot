# X1Bot Environment Variables
# Copy this to .env and fill in the real values

NODE_ENV=production

# Domains
API_DOMAIN=api.n9n.archcode.space
FRONTEND_DOMAIN=x1bot.cloud
FRONTEND_URL=https://x1bot.cloud
BACKEND_URL=https://api.n9n.archcode.space
CORS_ORIGIN=https://x1bot.cloud,https://www.x1bot.cloud

# Frontend public endpoints (used at build time)
NEXT_PUBLIC_API_URL=https://api.n9n.archcode.space
NEXT_PUBLIC_WS_URL=https://api.n9n.archcode.space

# Database
DATABASE_URL=postgresql://db_user:db_password@postgres_vps:5432/db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_NAME=db_name

# Redis
REDIS_PASSWORD=change_this_to_a_random_long_string

# Auth
JWT_SECRET=use_a_strong_random_secret_at_least_32_chars
WEBHOOK_SECRET=use_a_strong_random_secret_for_hmac

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_too
MINIO_BUCKET=x1bot

# Browserless
BROWSERLESS_TOKEN=change_this_browserless_token

# Security
TRUST_PROXY=1
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100

# VAPID keys for PWA push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@x1bot.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
